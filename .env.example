# Database Configuration
# For cloud databases (Supabase, Neon, Railway, Render, etc.):
DATABASE_URL=postgresql://user:password@host:port/database

# For local development with Docker:
# DATABASE_URL=postgresql://agro_user:agro_password@postgres:5432/agro_quote_system

# Leave empty to use SQLite for local development (no setup required)
# DATABASE_URL=

# Session Secret (change this in production!)
SESSION_SECRET=wichi-farms-secret-change-in-prod

# Server Port
PORT=5000

# Optional: Node Environment
NODE_ENV=development
